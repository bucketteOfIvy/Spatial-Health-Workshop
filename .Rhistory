```{r}
points <- st_transform(points, 3435)
tm_shape(areas) + tm_polygons() +
tm_shape(points) + tm_dots(size = 1)
pipr <- st_join(points, areas)
head(pipr)
dim(pipr)
dim(points)
dim(areas)
ptcount <- as.data.frame(table(pipr$Zip))
head(ptcount)
names(ptcount) <- c("zip", "MetClnc")
head(ptcount)
head(areas)
